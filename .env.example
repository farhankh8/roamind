# =============================================================================
# ROAMIND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!
# =============================================================================

# =============================================================================
# FIREBASE CONFIG (Required)
# =============================================================================
# Get these from Firebase Console > Project Settings > General > Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# =============================================================================
# APP CONFIG
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# EMAILJS (Optional - for contact forms)
# =============================================================================
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# =============================================================================
# OPENROUTER (FREE AI - $1 CREDIT ON SIGNUP, NO CREDIT CARD)
# =============================================================================
# Get free key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# =============================================================================
# FOR VERCEL DEPLOYMENT
# =============================================================================
# Add all NEXT_PUBLIC_* variables to Vercel Project Settings
# Add OPENROUTER_API_KEY to Vercel Environment Variables (not exposed to public)